//Get Requested for Computer Info

function onChange(control, oldValue, newValue, isLoading) {
    if (isLoading) {
        return;
    }

    if (newValue == '') {
        g_form.clearValue('computer_asset');
        g_form.clearValue('computer_asset_number');
        return;
    } else {
        g_form.clearValue('computer_asset');
        g_form.clearValue('computer_asset_number');
        var ga = new GlideAjax('GetUserComputerInfo');
        ga.addParam('sysparm_name', 'getComputerRecords');
        ga.addParam('sysparm_request', newValue);
        ga.addParam();
        ga.getXML(getInfo);
    }

    function getInfo(response) {
        var info = response.responseXML.documentElement.getAttribute('answer');
        g_form.setValue('computer_asset', info);
    }
	
}

//Populate Computer Type OnChg 

function onChange(control, oldValue, newValue, isLoading) {
    if (isLoading || newValue == '') {
        g_form.setValue('computer_type_std', '-- None --');
        return;
    }

    var networkadd = g_form.getValue('network');
	var compCategory = g_form.getValue('computer_category_std');
    g_form.setValue('computer_type_std', '-- None --');
    var ga = new GlideAjax('GetLookupCategoryType');
    ga.addParam('sysparm_name', 'getComputerType');
	ga.addParam('sysparm_lookup2', compCategory);
    ga.addParam('sysparm_netwrkAdd', networkadd);
    ga.getXML(lookup3);

    function lookup3(response) {
        var ans = response.responseXML.documentElement.getAttribute('answer');
        var lookup3Val = JSON.parse(ans);
        g_form.clearOptions('computer_type_std');
        g_form.addOption('computer_type_std', '', '-- None --');
        for (var i = 0; i < lookup3Val.length; i++) {
            g_form.addOption('computer_type_std', lookup3Val[i], lookup3Val[i]);
        }
    }
}

